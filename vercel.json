{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "index.html",  "use": "@vercel/static" },
    { "src": "pages/**",    "use": "@vercel/static" },
    { "src": "css/**",      "use": "@vercel/static" },
    { "src": "js/**",       "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/submit", "dest": "/api/submit.js" },
    { "src": "/api/ideas",  "dest": "/api/ideas.js"  },
    { "src": "/(.*)",       "dest": "/$1"             }
  ]
}